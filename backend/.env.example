APP_ENV=development
APP_NAME=SecureAudit API
APP_PORT=8000

DATABASE_URL=postgresql://secureaudit:secureaudit@localhost:5432/secureaudit

AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_CLIENT_ID=your-client-id
AUTH0_CLIENT_SECRET=your-client-secret
AUTH0_AUDIENCE=https://your-api
AUTH0_PRIVATE_KEY_PATH=./private-key.pem
AUTH0_ORG_ID=

GITHUB_API_BASE=https://api.github.com
TOKEN_EXCHANGE_SCOPE_READ=repo:read
TOKEN_EXCHANGE_SCOPE_WRITE=repo:write

OPENFGA_API_URL=http://localhost:8080
OPENFGA_STORE_ID=your-store-id
OPENFGA_MODEL_ID=your-model-id
